{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth/setup", "dest": "/api/auth/setup.js" },
    { "src": "/api/auth/me", "dest": "/api/auth/me.js" },
    { "src": "/api/players/parents", "dest": "/api/players/parents.js" },
    { "src": "/api/carpool/offer", "dest": "/api/carpool/offer.js" },
    { "src": "/api/carpool/claim", "dest": "/api/carpool/claim.js" },
    { "src": "/api/([^/]+)$", "dest": "/api/$1.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
